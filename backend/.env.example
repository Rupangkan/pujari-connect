# Copy to .env and fill. NEVER commit the real .env.
DATABASE_URL="file:./dev.db"

# 32+ random bytes. Generate: openssl rand -hex 32
JWT_SECRET=""

PORT=3001
# MUST be "production" in prod, or dev auth bypass stays open.
NODE_ENV=development

ADMIN_USERNAME="admin"
# bcrypt hash, never plaintext. node -e "console.log(require('bcryptjs').hashSync('PW',10))"
ADMIN_PASSWORD_HASH=""

# Google OAuth client ID. Blank disables /api/auth/google.
GOOGLE_CLIENT_ID=""
